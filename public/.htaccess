# ─── Apache configuration for React SPA (Namecheap shared hosting) ───────────

Options -MultiViews
Options -Indexes

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove trailing slashes (except root)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route all other requests to index.html (SPA fallback)
  RewriteRule ^ /index.html [L]
</IfModule>

# ─── Cache Control ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: no cache (always fetch fresh for SPA routing)
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Hashed JS/CSS assets: cache aggressively (Vite adds content hashes)
  <FilesMatch "\.(js|css|mjs)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images, fonts
  <FilesMatch "\.(ico|png|jpg|jpeg|gif|webp|svg|woff|woff2|ttf|otf)$">
    ExpiresDefault "access plus 6 months"
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>
</IfModule>

# ─── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ─── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ─── Deny access to hidden files ──────────────────────────────────────────────
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>
